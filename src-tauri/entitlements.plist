<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- JIT & unsigned executable memory: TauriのWKWebView/JSCに必要 -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- ネットワーク: LAN HTTP サーバとスマホから受け取るため必要 -->
  <key>com.apple.security.network.server</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- ユーザーファイルアクセス: 領収書のインポート・PDFエクスポート -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- 写真自動取込 (Phase 1): iCloud Photos 経由で iPhone の写真ライブラリ
       にアクセスし、領収書候補を抽出する機能。初回利用時に macOS の標準
       同意ダイアログが表示される。 -->
  <key>com.apple.security.personal-information.photos-library</key>
  <true/>
</dict>
</plist>
